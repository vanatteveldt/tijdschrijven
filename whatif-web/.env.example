# Copy this file to .env and fill in the values.

# Outlook calendar ICS URL
# To get this URL:
#   1. Open Outlook (web or desktop) and go to Calendar
#   2. Right-click the calendar you want to share → "Sharing and permissions"
#      (in Outlook Web: Settings gear → View all Outlook settings → Calendar → Shared calendars)
#   3. Under "Publish a calendar", select the calendar and set visibility to "All details"
#   4. Click "Publish" — you will see an ICS link and an HTML link
#   5. Copy the ICS link
# Note: this URL gives anyone read access to your calendar — treat it as a secret.
CALENDAR_ICS_URL=https://outlook.office365.com/owa/calendar/.../.../calendar.ics

# GitHub personal access token
# To create one:
#   1. Go to https://github.com/settings/tokens
#   2. Click "Generate new token (classic)"
#   3. Give it a name, set an expiry, and tick the "repo" scope (read access is enough)
#   4. Click "Generate token" and copy the value — it won't be shown again
GITHUB_TOKEN=ghp_...

# GitHub username whose commits to scan
GITHUB_USER=vanatteveldt

# Comma-separated list of GitHub repos to scan (owner/repo format)
GITHUB_REPOS=owner/repo1,owner/repo2
